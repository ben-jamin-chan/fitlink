{
  "expo": {
    "name": "fit-link",
    "slug": "fit-link",
    "scheme": "fitlink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.fitlink.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "package": "com.fitlink.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow fit-link to use Face ID for biometric login."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {}
      ],
      "expo-camera",
      [
        "react-native-health",
        {
          "NSHealthShareUsageDescription": "fitlink reads your activity to show your fitness stats to matches.",
          "NSHealthUpdateUsageDescription": "fitlink does not write to Apple Health."
        }
      ],
      "react-native-google-fit"
    ]
  }
}
