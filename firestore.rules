rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userCreateKeys() {
      return [
        'uid',
        'firstName',
        'dateOfBirth',
        'gender',
        'location',
        'photos',
        'bio',
        'height',
        'religion',
        'activities',
        'fitnessLevel',
        'workoutFrequency',
        'dietaryPreference',
        'fitnessGoals',
        'smoking',
        'drinking',
        'lookingFor',
        'preferences',
        'stats',
        'subscription',
        'verified',
        'paused',
        'banned',
        'language',
        'createdAt',
        'lastActive'
      ];
    }

    function serverOnlyUserFields() {
      return [
        'uid',
        'age',
        'stats',
        'subscription',
        'banned',
        'banReason',
        'bannedAt',
        'verified',
        'createdAt'
      ];
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && !('age' in request.resource.data)
        && request.resource.data.keys().hasAll([
          'uid',
          'firstName',
          'dateOfBirth',
          'gender',
          'location',
          'photos',
          'bio',
          'height',
          'activities',
          'fitnessLevel',
          'workoutFrequency',
          'dietaryPreference',
          'fitnessGoals',
          'smoking',
          'drinking',
          'lookingFor',
          'preferences',
          'stats',
          'subscription',
          'verified',
          'paused',
          'banned',
          'language',
          'createdAt',
          'lastActive'
        ])
        && request.resource.data.keys().hasOnly(userCreateKeys())
        && request.resource.data.stats.keys().hasOnly(['likes', 'passes', 'matches'])
        && request.resource.data.stats.likes == 0
        && request.resource.data.stats.passes == 0
        && request.resource.data.stats.matches == 0
        && request.resource.data.subscription.keys().hasOnly(['tier'])
        && request.resource.data.subscription.tier == 'free'
        && request.resource.data.verified == false
        && request.resource.data.paused == false
        && request.resource.data.banned == false;
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(serverOnlyUserFields());
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
